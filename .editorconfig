# Editor configuration, see http://editorconfig.org
root = true

[*]
tab_width = 2
charset = utf-8
indent_size = 2
indent_style = space
max_line_length = 100
insert_final_newline = true
trim_trailing_whitespace = true

[*.{gradle,sh,groovy}]
indent_size = 4

[*.bat]
indent_size = 4

[*.md]
max_line_length = off
trim_trailing_whitespace = false
